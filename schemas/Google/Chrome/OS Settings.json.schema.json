{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "properties": {
    "Arc Package": {
      "type": "array"
    },
    "OS Preferences": {
      "type": "array"
    },
    "OS Priority Preferences": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "preference": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "Printers": {
      "type": "array"
    }
  }
}