{
  "$schema": "http://json-schema.org/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "context_time": {
        "type": "string"
      },
      "context_receiver_service_timestamp": {
        "type": "string"
      },
      "context_device_manufacturer": {
        "type": "string"
      },
      "context_device_model": {
        "type": "string"
      },
      "context_device_type": {
        "type": "string"
      },
      "context_os_name": {
        "type": "string"
      },
      "context_os_version": {
        "type": "string"
      },
      "context_application_version": {
        "type": "string"
      },
      "context_conn_country": {
        "type": "string"
      },
      "message_total_num_tracks": {
        "type": "integer"
      },
      "message_num_downloaded_tracks": {
        "type": "integer"
      },
      "message_num_downloaded_tracks_keyless": {
        "type": "integer"
      },
      "message_total_num_links": {
        "type": "integer"
      },
      "message_total_num_links_keyless": {
        "type": "integer"
      },
      "message_context_num_links_map": {
        "type": "integer"
      },
      "message_linktype_num_tracks_map": {
        "type": "integer"
      },
      "message_track_limit": {
        "type": "integer"
      },
      "message_expiry": {
        "type": "integer"
      },
      "message_change_reason": {
        "type": "string"
      },
      "message_offline_keys": {
        "type": "integer"
      },
      "message_cached_keys": {
        "type": "integer"
      },
      "message_total_num_episodes": {
        "type": "integer"
      },
      "message_num_downloaded_episodes": {
        "type": "integer"
      },
      "message_episode_limit": {
        "type": "integer"
      },
      "message_episode_expiry": {
        "type": "integer"
      },
      "message_abp_chapter_expiry": {
        "type": "integer"
      },
      "message_schedule_stats_map": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "key": {
              "type": "string"
            },
            "value": {
              "type": "integer"
            }
          }
        }
      },
      "message_update_stats_map": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                },
                "value": {
                  "type": "integer"
                }
              }
            }
          }
        ]
      },
      "message_num_update_all_lists": {
        "type": "integer"
      },
      "message_key_cache_limit": {
        "type": "integer"
      },
      "message_key_cache_max_offline_seconds": {
        "type": "integer"
      },
      "timestamp_utc": {
        "type": "string"
      }
    }
  }
