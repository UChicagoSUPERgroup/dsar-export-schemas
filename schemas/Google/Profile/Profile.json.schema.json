{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "properties": {
    "name": {
      "type": "object",
      "properties": {
        "givenName": {
          "type": "string"
        },
        "familyName": {
          "type": "string"
        },
        "formattedName": {
          "type": "string"
        }
      }
    },
    "displayName": {
      "type": "string"
    },
    "emails": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string"
          }
        }
      }
    },
    "gender": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        }
      }
    }
  }
}