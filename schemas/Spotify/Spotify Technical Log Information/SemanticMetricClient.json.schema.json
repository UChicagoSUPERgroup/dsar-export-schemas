      "context_time": {
        "type": "string"
      },
      "context_receiver_service_timestamp": {
        "type": "string"
      },
      "context_user_agent": {
        "type": "string"
      },
      "context_application_version": {
        "type": "integer"
      },
      "context_conn_country": {
        "type": "string"
      },
      "context_device_manufacturer": {
        "type": "integer"
      },
      "context_device_model": {
        "type": "integer"
      },
      "context_device_type": {
        "type": "integer"
      },
      "context_os_name": {
        "type": "integer"
      },
      "context_os_version": {
        "type": "integer"
      },
      "message_key": {
        "type": "string"
      },
      "message_metric_type": {
        "type": "string"
      },
      "message_component_id": {
        "type": "string"
      },
      "message_what": {
        "type": "string"
      },
