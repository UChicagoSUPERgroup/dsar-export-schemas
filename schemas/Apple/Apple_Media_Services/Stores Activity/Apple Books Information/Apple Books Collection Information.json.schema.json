{
  "$schema": "http://json-schema.org/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "title": {
        "type": "string"
      },
      "lastModification": {
        "type": "string"
      },
      "deleted": {
        "type": "boolean"
      },
      "contents": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": [
                "integer",
                "string"
              ]
            },
            "description": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}